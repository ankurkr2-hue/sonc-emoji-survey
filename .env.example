# Which backend to use: "excel" (default) or "supabase"
DB_BACKEND=excel

# Required when DB_BACKEND=excel
EXCEL_DATA_PATH=./data/survey-data.xlsx

# Required when DB_BACKEND=supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin password
ADMIN_SECRET=changeme
